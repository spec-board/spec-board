# Application port
PORT=3000

# Database connection (Supabase)
# Pooled connection for Prisma queries
POSTGRES_PRISMA_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Direct connection for Prisma migrations
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/postgres"

# Redis (optional, for background jobs)
REDIS_URL="redis://localhost:6379"

# ============================================
# AI Provider API Keys (optional)
# Set these to auto-import providers via Settings > AI > Import .env
# ============================================

# OpenAI Compatible API
OPENAI_API_KEY="sk-..."
OPENAI_BASE_URL="https://api.openai.com/v1"    # Optional: override base URL (Ollama, LM Studio, etc.)
OPENAI_MODEL="gpt-4o"                           # Optional: override default model

# Anthropic Claude
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_BASE_URL="https://api.anthropic.com"  # Optional: override base URL
ANTHROPIC_MODEL="claude-sonnet-4-20250514"       # Optional: override default model

# Google Gemini
GEMINI_API_KEY="AIza..."
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"  # Optional
GEMINI_MODEL="gemini-2.5-flash"                  # Optional: override default model

# Mistral / Codestral
MISTRAL_API_KEY="sk-..."
MISTRAL_MODEL="codestral-latest"                 # Optional: override default model

# Qwen (API key mode)
QWEN_API_KEY="sk-..."
QWEN_MODEL="qwen-max"                           # Optional: override default model

# iFlow
IFLOW_API_KEY="..."
IFLOW_MODEL="Qwen3-Coder"                       # Optional: override default model
