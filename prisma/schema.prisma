// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  seed = "tsx prisma/seed.ts"
}

// generator erd {
//   provider = "prisma-erd-generator"
// }

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// Local project reference (existing)
model Project {
  id          String   @id @default(uuid())
  name        String   @unique // URL slug (e.g., "my-project")
  displayName String   @map("display_name")
  description String?
  filePath    String?  @map("file_path") // Optional - for migration from filesystem

  // Database-first fields
  isCloud     Boolean  @default(false) @map("is_cloud")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  features       Feature[]
  constitution   Constitution?
  mindMapNodes   MindMapNode[]
  mindMapEdges   MindMapEdge[]

  @@map("projects")
}

// ============================================
// Feature/Task Management Models (Database-first)
// ============================================

// Feature model (replaces filesystem-based features)
model Feature {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  featureId   String   // e.g., "001-user-login" (from spec)
  name        String
  description String?
  stage       String   @default("backlog") // backlog, specs, plan, tasks, analyze
  status      String   @default("backlog") // backlog, planning, in_progress, done
  order       Int      @default(0)

  // Constitution version at time of feature creation
  constitutionVersionId String? @map("constitution_version_id")

  // Content stored in database (database-first, no filesystem)
  specContent         String?  @db.Text // Includes clarifications appended
  clarificationsContent String? @db.Text // Standalone clarifications
  planContent        String?  @db.Text
  tasksContent      String?  @db.Text
  analysisContent   String?  @db.Text
  researchContent   String?  @db.Text
  dataModelContent  String?  @db.Text
  quickstartContent String?  @db.Text
  // Multiple files - stored as JSON
  contractsContent  String?  @db.Text // JSON array of {name, content}
  checklistsContent String?  @db.Text // JSON array of {name, content}

  // Background job status for stage transitions
  jobStatus        String?   @default("idle") @map("job_status") // idle, queued, running, completed, failed
  jobProgress      Int?      @default(0) @map("job_progress") // 0-100
  jobMessage       String?   @map("job_message") // Current step message
  jobStartedAt     DateTime? @map("job_started_at")
  jobCompletedAt   DateTime? @map("job_completed_at")
  inngestRunId     String?   @map("inngest_run_id")

  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  constitutionVersion ConstitutionVersion? @relation(fields: [constitutionVersionId], references: [id], onDelete: SetNull)
  userStories UserStory[]
  tasks       Task[]

  @@unique([projectId, featureId])
  @@index([projectId, order])
  @@map("features")
}

// User Story model
model UserStory {
  id          String   @id @default(uuid())
  featureId   String   @map("feature_id")
  storyId     String   // e.g., "US1"
  title       String
  description String?
  status      String   @default("pending") // pending, in_progress, completed
  order       Int      @default(0)

  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  feature     Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@unique([featureId, storyId])
  @@index([featureId, order])
  @@map("user_stories")
}

// Task model (granular than markdown tasks)
model Task {
  id          String   @id @default(uuid())
  featureId   String   @map("feature_id")
  userStoryId String?  @map("user_story_id")
  taskId      String   // e.g., "T001"
  title       String
  description String?
  status      String   @default("pending") // pending, in_progress, completed
  priority    String   @default("P") // P (High), M (Medium), L (Low)
  order       Int      @default(0)

  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  feature     Feature    @relation(fields: [featureId], references: [id], onDelete: Cascade)
  userStory   UserStory? @relation(fields: [userStoryId], references: [id], onDelete: SetNull)

  @@unique([featureId, taskId])
  @@index([featureId, order])
  @@map("tasks")
}

// ============================================
// Constitution Model (Database-first)
// ============================================

model Constitution {
  id        String   @id @default(uuid())
  projectId String   @unique @map("project_id")
  title     String?
  content   String   // Full markdown content

  // Principles stored as JSON
  principles Json?   // Array of {name, description}

  // Metadata
  version         String?
  ratifiedDate    DateTime? @map("ratified_date")
  lastAmendedDate DateTime? @map("last_amended_date")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  versions ConstitutionVersion[]

  @@map("constitutions")
}

// Constitution Version History (read-only)
model ConstitutionVersion {
  id            String   @id @default(uuid())
  constitutionId String @map("constitution_id")
  version       String
  content       String   @db.Text // Snapshot of full markdown content
  description   String?  // Project description at this version
  principles    Json    // Array of {name, description} at this version

  // Change info
  changeType    String  @default("update") // "create", "update", "minor", "major"
  changeNote    String? // Optional note about what changed

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  constitution Constitution @relation(fields: [constitutionId], references: [id], onDelete: Cascade)
  features     Feature[]

  @@map("constitution_versions")
}

// ============================================
// Mind Map Models (Brainstorming Tool)
// ============================================

model MindMapNode {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  label     String   @default("New Idea")
  color     String   @default("#f6ad55")
  positionX Float    @default(0) @map("position_x")
  positionY Float    @default(0) @map("position_y")
  parentId  String?  @map("parent_id")
  type      String   @default("default")
  metadata  Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      MindMapNode?  @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    MindMapNode[] @relation("NodeHierarchy")
  sourceEdges MindMapEdge[] @relation("SourceEdges")
  targetEdges MindMapEdge[] @relation("TargetEdges")

  @@map("mind_map_nodes")
}

model MindMapEdge {
  id       String  @id @default(uuid())
  projectId String @map("project_id")
  sourceId String  @map("source_id")
  targetId String  @map("target_id")
  label    String?
  type     String  @default("default")

  createdAt DateTime @default(now()) @map("created_at")

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source  MindMapNode @relation("SourceEdges", fields: [sourceId], references: [id], onDelete: Cascade)
  target  MindMapNode @relation("TargetEdges", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@map("mind_map_edges")
}

// ============================================
// Application Settings (Database-first)
// ============================================

model AppSettings {
  id        String   @id @default(uuid())
  key       String   @unique // 'app-settings' - single row for all settings
  theme     String   @default("dark") // light, dark, system
  shortcutsEnabled Boolean @default(true)
  language  String   @default("vi") // AI output language: vi, en, zh, ja, ko

  // AI Settings - OpenAI-Compatible API only
  aiProvider        String   @default("openai") // openai only
  openaiBaseUrl     String?  // Base URL for OpenAI-compatible API (e.g., Ollama, LM Studio)
  openaiApiKey     String?  // API key (Encrypted in production)
  openaiModel      String?  // Model name

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// ============================================
// AI Provider Configurations (multi-provider load balancing)
// ============================================

model AIProviderConfig {
  id          String   @id @default(uuid())
  provider    String   // openai, qwen, codex, kimi, iflow, anthropic, gemini, mistral
  label       String   // Display name
  baseUrl     String   // API base URL
  model       String   // Model name
  apiKey      String?  // API key
  enabled     Boolean  @default(true)
  priority    Int      @default(0) // Lower = higher priority (tried first)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("ai_provider_configs")
}
